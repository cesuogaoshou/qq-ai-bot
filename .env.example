# =============================================================================
# QQ AI Bot environment template
# Copy this file to .env and fill local values.
# Advanced capabilities stay disabled until provider, price, and quota are confirmed.
# =============================================================================

# -----------------------------------------------------------------------------
# Bot identity and target scope
# -----------------------------------------------------------------------------
BOT_QQ=
TARGET_GROUP_ID=
BOT_ADMIN_QQ_IDS=
BOT_DEFAULT_MODE=mention_only

# -----------------------------------------------------------------------------
# OneBot connection
# -----------------------------------------------------------------------------
ONEBOT_WS_URL=ws://127.0.0.1:3001
ONEBOT_HTTP_URL=http://127.0.0.1:3000
ONEBOT_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# LLM provider - Volcano Ark / OpenAI-compatible chat completions
# -----------------------------------------------------------------------------
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_MODEL=doubao-seed-2.0-lite
LLM_API_KEY=

# -----------------------------------------------------------------------------
# Runtime limits and memory
# -----------------------------------------------------------------------------
BOT_MAX_CONTEXT_MESSAGES=30
BOT_SUMMARY_RECENT_LIMIT=100
BOT_MEMORY_MAX_MESSAGES=5000
BOT_GROUP_COOLDOWN_SECONDS=20
BOT_USER_COOLDOWN_SECONDS=10
BOT_MAX_REPLY_CHARS=300

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
SQLITE_PATH=./data/bot.sqlite3

# -----------------------------------------------------------------------------
# Web search - default disabled
# Enable only after configuring provider key and confirming quota/cost.
# -----------------------------------------------------------------------------
ENABLE_WEB_SEARCH=false
WEB_SEARCH_PROVIDER=disabled
TAVILY_API_KEY=
WEB_SEARCH_BASE_URL=https://api.tavily.com
DAILY_SEARCH_LIMIT_PER_GROUP=20
DAILY_SEARCH_LIMIT_PER_USER=5
SEARCH_MAX_RESULTS=3

# -----------------------------------------------------------------------------
# Image input - default disabled
# Empty IMAGE_INPUT_MODEL means reusing LLM_MODEL.
# -----------------------------------------------------------------------------
ENABLE_IMAGE_INPUT=false
IMAGE_INPUT_MODEL=
IMAGE_MAX_BYTES=5242880
DAILY_IMAGE_LIMIT_PER_GROUP=5
DAILY_IMAGE_LIMIT_PER_USER=5

# -----------------------------------------------------------------------------
# Image generation - reserved, not implemented yet
# -----------------------------------------------------------------------------
ENABLE_IMAGE_GENERATION=false

# -----------------------------------------------------------------------------
# Voice transcription - reserved, not implemented yet
# -----------------------------------------------------------------------------
ENABLE_VOICE_TRANSCRIPTION=false
VOICE_TRANSCRIPTION_PROVIDER=disabled
VOICE_TRANSCRIPTION_MODEL=
VOICE_RECORD_FORMAT=mp3
VOICE_MAX_SECONDS=60
VOICE_MAX_BYTES=10485760
DAILY_VOICE_LIMIT_PER_GROUP=3
DAILY_VOICE_LIMIT_PER_USER=1
